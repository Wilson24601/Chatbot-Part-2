<Window x:Class="AwarenessChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" Height="700" Width="900"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E">
    <Window.Resources>
        <Style TargetType="Button" x:Key="TopicButton">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1ABC9C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ASCII Art Logo -->
        <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="8" Margin="0,0,0,10" Padding="8">
            <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#4CAF50" TextAlignment="Center"
                       Text="  ██████╗██╗   ██╗██████╗ ███████╗██████╗ ██████╗  ██████╗ ████████╗&#x0a; ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗██╔══██╗██╔═══██╗╚══██╔══╝&#x0a; ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝██████╔╝██║   ██║   ██║   &#x0a; ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗██╔══██╗██║   ██║   ██║   &#x0a; ╚██████╗   ██║   ██████╔╝███████╗██║  ██║██████╔╝╚██████╔╝   ██║   &#x0a;  ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝╚═════╝  ╚═════╝    ╚═╝   "/>
        </Border>

        <!-- Chat History -->
        <ListBox x:Name="ChatListBox" Grid.Row="2" Background="#2A2A2A" BorderBrush="#444"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,5,0,5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8" Margin="5" Padding="8"
                            Background="{Binding BackgroundColor}" HorizontalAlignment="{Binding Alignment}">
                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="White"
                                   FontSize="14" FontWeight="{Binding FontWeight}"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input Area -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InputBox" Grid.Column="0" Padding="10" FontSize="14" 
                     Background="#3A3A3A" Foreground="White" BorderThickness="0"
                     KeyDown="InputBox_KeyDown"/>
            <Button x:Name="SendBtn" Grid.Column="1" Content="Send" Width="70" Margin="8,0,0,0"
                    Background="#1ABC9C" Foreground="White" BorderThickness="0" FontWeight="Bold"
                    Click="SendBtn_Click" Cursor="Hand"/>
        </Grid>

        <!-- Action Buttons with Speech Toggle -->
        <WrapPanel Grid.Row="4" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button Style="{StaticResource TopicButton}" Click="ActionButton_Click" Tag="addtask">Add Task</Button>
            <Button Style="{StaticResource TopicButton}" Click="ActionButton_Click" Tag="quiz">Quiz</Button>
            <Button Style="{StaticResource TopicButton}" Click="ActionButton_Click" Tag="showlog">Show Log</Button>
            <Button Style="{StaticResource TopicButton}" Click="ActionButton_Click" Tag="viewtasks">My Tasks</Button>
            <Button x:Name="SpeechToggleBtn" Style="{StaticResource TopicButton}" Click="SpeechToggle_Click" Background="#5D6D7E">Speech: On</Button>
        </WrapPanel>

        <!-- Topic Buttons -->
        <WrapPanel Grid.Row="5" Margin="0,5,0,0" HorizontalAlignment="Center">
            <Button Style="{StaticResource TopicButton}" Click="Topic_Click" Tag="password">Password Safety</Button>
            <Button Style="{StaticResource TopicButton}" Click="Topic_Click" Tag="phishing">Phishing</Button>
            <Button Style="{StaticResource TopicButton}" Click="Topic_Click" Tag="safe browsing">Safe Browsing</Button>
            <Button Style="{StaticResource TopicButton}" Click="Topic_Click" Tag="strong passwords">Strong Passwords</Button>
            <Button Style="{StaticResource TopicButton}" Click="Topic_Click" Tag="2fa">Two-Factor Auth</Button>
            <Button Style="{StaticResource TopicButton}" Click="Topic_Click" Tag="social engineering">Social Engineering</Button>
            <Button Style="{StaticResource TopicButton}" Click="Exit_Click" Background="#C0392B">Exit</Button>
        </WrapPanel>
    </Grid>
</Window>